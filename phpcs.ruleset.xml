<?xml version="1.0"?>
<ruleset name="php-basic-auth">
	<description>Code sniffing rules for use with HM PHP Basic Auth plugin</description>

	<!-- Use HM Coding Standards -->
	<rule ref="vendor/humanmade/coding-standards" />

	<!-- Add PHPDoc rules -->
	<rule ref="WordPress-Docs" />

	<!-- phpcompatibility/php-compatibility 9.x cannot run under PHP 8.x -->
	<rule ref="PHPCompatibility">
		<exclude name="PHPCompatibility" />
	</rule>

	<exclude-pattern>php-codesniffer/*</exclude-pattern>
	<exclude-pattern>**/tests/*</exclude-pattern>
</ruleset>
